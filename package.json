{
  "name": "lux-framework",
  "version": "1.2.3",
  "description": "Build scalable, Node.js-powered REST APIs with almost no code.",
  "repository": "github:postlight/lux",
  "keywords": [
    "mvc",
    "api",
    "lux",
    "jsonapi",
    "json-api",
    "rest",
    "framework"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "bin": {
    "lux": "bin/lux"
  },
  "scripts": {
    "build": "node build.mjs",
    "clean": "shx rm -rf .nyc_output coverage build dist test/test-app/dist test-results.xml",
    "codecov": "nyc report --reporter=lcov > coverage.lcov && curl -s https://codecov.io/bash | bash",
    "flow": "flow check",
    "typecheck": "tsc --noEmit",
    "types": "shx rm -rf flow-typed && flow-typed install",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:mocha && pnpm run test:vitest",
    "test:mocha": "nyc -i ./lib/babel-hook.js --instrument false --source-map false mocha --opts mocha.opts",
    "test:vitest": "vitest run",
    "debugger": "node test/utils/debugger/dist/debug.js",
    "build:debugger": "rollup -c test/utils/debugger/rollup.config.js"
  },
  "author": "Zachary Golba",
  "license": "MIT",
  "homepage": "https://lux.postlight.com",
  "bugs": {
    "url": "https://github.com/postlight/lux/issues"
  },
  "engines": {
    "node": ">= 20"
  },
  "packageManager": "pnpm@10.34.5",
  "dependencies": {
    "ansi-regex": "^5.0.1",
    "babel-eslint": "^7.2.3",
    "chalk": "^4.1.2",
    "commander": "^2.20.3",
    "fb-watchman": "^2.0.2",
    "inflection": "^1.13.4",
    "knex": "^0.16.3",
    "ora": "^5.4.1",
    "rollup": "0.43.1",
    "rollup-plugin-alias": "^1.3.1",
    "rollup-plugin-babel": "^3.0.7",
    "rollup-plugin-eslint": "^3.0.0",
    "rollup-plugin-json": "^2.1.1",
    "rollup-plugin-lux": "3.0.0",
    "rollup-plugin-node-resolve": "^3.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-flow": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.39.5",
    "@types/inflection": "1.13.2",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-core": "^6.24.1",
    "babel-plugin-istanbul": "^4.1.3",
    "babel-plugin-transform-es2015-modules-commonjs": "^6.24.1",
    "babel-preset-lux": "2.0.2",
    "chai": "3.5.0",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "faker": "4.1.0",
    "flow-bin": "0.38.0",
    "flow-typed": "2.1.2",
    "globals": "^17.7.0",
    "lux-framework": "link:.",
    "mocha": "3.4.1",
    "mocha-junit-reporter": "1.13.0",
    "node-fetch": "^2.7.0",
    "nyc": "10.3.2",
    "prettier": "^3.9.5",
    "rollup-plugin-multi-entry": "2.0.1",
    "shx": "^0.3.4",
    "sinon": "2.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "volta": {
    "node": "20.20.2"
  }
}
