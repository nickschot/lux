{
  "name": "lux-framework",
  "version": "1.2.3",
  "description": "Build scalable, Node.js-powered REST APIs with almost no code.",
  "repository": "github:postlight/lux",
  "keywords": [
    "mvc",
    "api",
    "lux",
    "jsonapi",
    "json-api",
    "rest",
    "framework"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "bin": {
    "lux": "bin/lux"
  },
  "scripts": {
    "build": "node build.mjs",
    "clean": "shx rm -rf coverage build dist test/test-app/dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "debugger": "node --enable-source-maps test/utils/debugger/dist/debug.js",
    "build:debugger": "node test/utils/debugger/build.mjs"
  },
  "author": "Zachary Golba",
  "license": "MIT",
  "homepage": "https://lux.postlight.com",
  "bugs": {
    "url": "https://github.com/postlight/lux/issues"
  },
  "engines": {
    "node": ">= 20"
  },
  "packageManager": "pnpm@10.34.5",
  "dependencies": {
    "ansi-regex": "^5.0.1",
    "babel-eslint": "^7.2.3",
    "chalk": "^4.1.2",
    "commander": "^2.20.3",
    "fb-watchman": "^2.0.2",
    "inflection": "^1.13.4",
    "knex": "^0.16.3",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^9.39.5",
    "@types/inflection": "1.13.2",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-core": "^6.24.1",
    "babel-preset-lux": "2.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "faker": "4.1.0",
    "globals": "^17.7.0",
    "lux-framework": "link:.",
    "node-fetch": "^2.7.0",
    "prettier": "^3.9.5",
    "shx": "^0.3.4",
    "sinon": "2.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "volta": {
    "node": "20.20.2"
  }
}
